{
  "manifest_version": 3,
  "name": "NeoGPT - Smart Page Assistant",
  "version": "1.0.0",
  "description": "AI-powered page summarizer and context-aware chat for any webpage.",
  "icons": {
    "48": "icons/logo_neogpt.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NeoGPT Assistant"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-xCM-Vb0h.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/content.js-xCM-Vb0h.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
